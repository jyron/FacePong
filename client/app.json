{
  "expo": {
    "name": "FacePong",
    "slug": "facepong",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "facepong",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07070f",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.facepong.app"
    },
    "android": {
      "package": "com.facepong.app",
      "adaptiveIcon": {
        "backgroundColor": "#07070f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "FacePong needs access to your photos so you can use a photo as your paddle.",
          "cameraPermission": "FacePong needs the camera so you can snap a selfie to use as your paddle."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      "expo-audio"
    ]
  }
}
