# dependencies
node_modules/

# server build output (Railway builds it from source on deploy)
server/dist/

# secrets / certs
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.env*.local

# logs / tooling noise
npm-debug.*
yarn-debug.*
yarn-error.*
*.tsbuildinfo
*.orig.*
.DS_Store

# local-only Claude tooling (skills, settings) + local deploy script — not part of the app
.claude/
deploy.sh

# Xcode build output (regenerated by xcodebuild/xcodegen)
ios/.build/
ios/.build-*/

# promo-video heavy intermediates (regenerable; Veo clips, seeds & finals ARE committed)
appstore/promo_video/gameplay/
appstore/promo_video/tiktok/gameplay/
appstore/promo_video/work/

# WIP app-icon design candidates (not part of a release; regenerable)
appstore/logo/

# generated audio staging (regenerated by synth_sfx.py / build_songs.sh; the shipped copies
# live in ios/.../Resources/sfx)
appstore/sfx_gen/
appstore/__pycache__/
