# dependencies
node_modules/

# server build output (Railway builds it from source on deploy)
server/dist/

# Expo / client builds
client/.expo/
client/dist/
client/web-build/
client/expo-env.d.ts
.metro-health-check*

# generated native projects (expo prebuild)
client/ios/
client/android/
client/.kotlin/

# secrets / certs
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.env*.local

# logs / tooling noise
npm-debug.*
yarn-debug.*
yarn-error.*
*.tsbuildinfo
*.orig.*
.DS_Store

# local-only Claude tooling (skills, settings) + local deploy script — not part of the app
.claude/
deploy.sh

# Xcode build output (regenerated by xcodebuild/xcodegen)
ios/.build/
ios/.build-dev/
ios/.build-archive/

# promo-video heavy intermediates (regenerable; Veo clips, seeds & finals ARE committed)
appstore/promo_video/gameplay/
appstore/promo_video/work/
