{
  "expo": {
    "name": "FacePong",
    "slug": "facepong",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "facepong",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07070f",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.facepong.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.facepong.app",
      "adaptiveIcon": {
        "backgroundColor": "#07070f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "FacePong needs access to your photos so you can use a photo as your paddle.",
          "cameraPermission": "FacePong needs the camera so you can snap a selfie to use as your paddle."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      "expo-audio",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "0c4120e8-6fb3-4af4-9ab6-7a0ef602a726"
      }
    },
    "owner": "jyronw"
  }
}
